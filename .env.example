# Kairosis — Environment Configuration
# Copy this file to .env and fill in your values
# Never commit .env to version control

# ─────────────────────────────────────────────
# Server
# ─────────────────────────────────────────────

PORT=3200
NODE_ENV=development

# ─────────────────────────────────────────────
# PostgreSQL
# ─────────────────────────────────────────────

POSTGRES_HOST=localhost
POSTGRES_PORT=5431
POSTGRES_DB=kairosis
POSTGRES_USER=kairosis
POSTGRES_PASSWORD=
DATABASE_URL=postgresql://${POSTGRES_USER}:${POSTGRES_PASSWORD}@${POSTGRES_HOST}:${POSTGRES_PORT}/${POSTGRES_DB}

# ─────────────────────────────────────────────
# RabbitMQ
# ─────────────────────────────────────────────

RABBITMQ_HOST=localhost
RABBITMQ_PORT=5671
RABBITMQ_USER=kairosis
RABBITMQ_PASSWORD=
RABBITMQ_URL=amqp://${RABBITMQ_USER}:${RABBITMQ_PASSWORD}@${RABBITMQ_HOST}:${RABBITMQ_PORT}
RABBITMQ_EXCHANGE=kairosis.topic

# ─────────────────────────────────────────────
# Encryption
# Generate with: openssl rand -hex 32
# ─────────────────────────────────────────────

ENCRYPTION_KEY=

# ─────────────────────────────────────────────
# Dashboard
# ─────────────────────────────────────────────

DASHBOARD_PORT=3001
NEXT_PUBLIC_API_URL=http://localhost:3200

# ─────────────────────────────────────────────
# Connectors — Gmail / IMAP
# ─────────────────────────────────────────────

# GMAIL_CLIENT_ID=
# GMAIL_CLIENT_SECRET=
# IMAP_HOST=
# IMAP_PORT=993
# IMAP_USER=
# IMAP_PASSWORD=

# ─────────────────────────────────────────────
# Connectors — Slack
# ─────────────────────────────────────────────

# Configured per workspace via dashboard
# SLACK_CLIENT_ID=
# SLACK_CLIENT_SECRET=

# ─────────────────────────────────────────────
# Connectors — GitHub
# ─────────────────────────────────────────────

# Configured per workspace via dashboard
# GITHUB_CLIENT_ID=
# GITHUB_CLIENT_SECRET=

# ─────────────────────────────────────────────
# Connectors — Google Calendar
# ─────────────────────────────────────────────

# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=

# ─────────────────────────────────────────────
# Connectors — Notion
# ─────────────────────────────────────────────

# Configured per workspace via dashboard
# NOTION_CLIENT_ID=
# NOTION_CLIENT_SECRET=

# ─────────────────────────────────────────────
# MinIO (object storage)
# ─────────────────────────────────────────────

MINIO_ENDPOINT=localhost
MINIO_PORT=9100
MINIO_USE_SSL=false
MINIO_ACCESS_KEY=kairosis
MINIO_SECRET_KEY=
MINIO_BUCKET=kairosis

# Claim-check: events larger than this are offloaded to MinIO (bytes, default 128 KB)
CLAIMCHECK_THRESHOLD_BYTES=131072
# How long presigned download URLs remain valid (seconds, default 60)
CLAIMCHECK_URL_EXPIRY_SECONDS=60

# ─────────────────────────────────────────────
# Poller
# ─────────────────────────────────────────────

# Default poll interval in seconds (can be overridden per connector)
POLLER_DEFAULT_INTERVAL=300