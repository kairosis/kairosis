{
  "manifest_version": 3,
  "name": "Kairosis",
  "version": "0.1.0",
  "description": "Sends browser activity to your Kairosis instance.",
  "permissions": ["tabs", "storage"],
  "host_permissions": ["<all_urls>"],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "Kairosis"
  }
}
