{
  "name": "browser-extension",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "apps/browser-extension/src",
  "projectType": "application",
  "tags": [],
  "targets": {
    "build": {
      "executor": "nx:run-commands",
      "outputs": ["{workspaceRoot}/dist/apps/browser-extension"],
      "options": {
        "command": "webpack-cli build --config apps/browser-extension/webpack.config.js"
      },
      "configurations": {
        "development": {
          "command": "webpack-cli build --config apps/browser-extension/webpack.config.js --mode development"
        }
      }
    }
  }
}
